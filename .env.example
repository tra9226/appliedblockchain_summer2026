# Copy this file to ".env" (same folder as hardhat.config.js) and fill in real values.
# NEVER commit the real .env — it contains a private key. Keep .env in .gitignore.

# 1) RPC endpoint for Sepolia. Get a free one from Alchemy or Infura.
#    Example: https://eth-sepolia.g.alchemy.com/v2/XXXXXXXXXXXXXXXX
SEPOLIA_RPC_URL=

# 2) Private key of your DEPLOYER / admin account (the one funded with Sepolia ETH).
#    Export it from MetaMask: Account details -> Show private key.
#    Paste it WITHOUT the 0x prefix is fine for Hardhat, with 0x also works.
#    Use a throwaway account you created for this class — never a real-money wallet.
PRIVATE_KEY=

# 3) Optional: Etherscan API key, only needed if you want to run `hardhat verify`.
#    Get one free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
